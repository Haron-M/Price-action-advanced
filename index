<!DOCTYPE html>
<html>

<head>
    <meta name="viewport" content="width=device-width ,initial-scale=1.0">
    <title>increase pro</title>
    <style>
        body {
            margin: 0;
            padding: 0;
        }

        header {
            background-color: rgb(101, 95, 57);
            text-align: center;
            color: white;
            padding: 10px;
            text-transform: capitalize;
            font-size: 23px;
            margin-bottom: 20px;
        }

        .container {
            text-align: center;
        }

        #companies {
            width: 250px;
            margin-top: 10px;
            border-radius: 4px;
            padding: 4px 6px;

        }

        #companies::placeholder {
            font-size: 13px;

        }

        label {
            font-size: 18px;
        }

        table {
            background-color: rgb(155, 159, 157);
            text-align: center;

            margin: 20px 50px;
            border-radius: 7px;
        }

        th {
            background-color: rgb(81, 73, 73);
            color: rgb(235, 232, 232);
            text-transform: capitalize;
            padding: 12px 10px;

        }

        td {
            background-color: rgb(153, 148, 148);
            padding: 10px 10px;

        }

        .tr2>td {
            background-color: rgb(81, 73, 73);
            font-weight: 500;
            font-size: 18px;
            color: rgb(235, 232, 232);
        }

        .display {
            font-size: 17px;
        }

        button {
            background-color: green;
            color: white;
            border-radius: 3px;
            padding: 4px 10px;
            margin-top: 10px;
            font-size: 15px;
            font-family: Arial, Helvetica, sans-serif;
            border: none;
        }

        button:active {
            opacity: 0.7;
        }
    </style>

<body>
    <header>
        price action
    </header>
    <div class="container">
        <label for="companies">Enter Number of Companies:</label><br>
        <input autofocus type="search" placeholder="Enter here..." id="companies"><br>
        <button id="download">download</button>
        <table id="table"></table>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script>

        document.querySelector('#companies').addEventListener('keydown', (event) => {
            if (event.key == 'Enter') {
                const input = document.querySelector('#companies').value;
                companies(input);

                document.querySelector('table').innerHTML = `
            <tr>
                <th>company name</th>
                <th>initial price</th>
                <th>Current price</th>
                <th>price/share gain</th>
                <th>initial amount</th>
                <th>tota value gain</th>
                <th>total amount</th>
            </tr>
           `
                iPrice(input);
                icPrice(input);
                Amount(input);
                // gross();
                display(input);
                bottom();
                document.querySelector('#companies').value = "";

            }
        })

        let compies = [];


        function companies(input) {
            for (i = 0; i < input; i++) {
                const company = prompt(`Enter name of company ${i + 1}:`);
                compies[i] = company.toUpperCase();
            }
        }
        let iprice = [];
        function iPrice(input) {
            for (i = 0; i < input; i++) {
                const init = prompt(`Enter initial share price for ${compies[i]}:`);
                iprice[i] = parseFloat(init);
            }
        }
        let icprice = [];
        function icPrice(input) {
            for (i = 0; i < input; i++) {
                const curr = prompt(`Enter current share price for ${compies[i]}:`);
                icprice[i] = parseFloat(curr);
            }
        }
        let ammount = [];
        function Amount(input) {
            for (i = 0; i < input; i++) {
                const init = prompt(`Enter initial amount price for ${compies[i]}:`);
                ammount[i] = parseFloat(init);
            }
        }
        function TAmount() {
            let sum = 0;
            for (i = 0; i < ammount.length; i++) {
                sum += ammount[i];
            }
            return sum;
        }
        let grossAmount = 0;
        let grossValueGain = 0;

        function display(input) {
            for (i = 0; i < input; i++) {
                const table = document.querySelector('table');
                let tr1 = document.createElement('tr');
                let td1 = document.createElement('td');
                let td2 = document.createElement('td');
                let td3 = document.createElement('td');
                let td4 = document.createElement('td');
                let td5 = document.createElement('td');
                let td6 = document.createElement('td');
                let td7 = document.createElement('td');
                table.append(tr1);
                tr1.append(td1);
                tr1.append(td2);
                tr1.append(td3);
                tr1.append(td4);
                tr1.append(td5);
                tr1.append(td6);
                tr1.append(td7);
                let shareGain = icprice[i] - iprice[i];
                let valueIncrease = (ammount[i] / iprice[i]) * shareGain;
                grossValueGain += valueIncrease;
                grossAmount += ammount[i] + ((ammount[i] / iprice[i]) * shareGain);
                const fAmount = ammount[i] + ((ammount[i] / iprice[i]) * shareGain);
                const fAmount1 = Number(fAmount.toFixed(2)).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                td1.innerText = compies[i];
                td2.innerText = iprice[i].toFixed(2);
                td3.innerText = icprice[i].toFixed(2);
                td4.innerText = shareGain.toFixed(2);
                td5.innerText = ammount[i].toFixed(2);
                td6.innerText = valueIncrease.toFixed(2);
                td7.innerText = fAmount1;

            }
        }
        function bottom() {
            let tr2 = document.createElement('tr');
            let td = document.createElement('td');
            let td4 = document.createElement('td');
            let td5 = document.createElement('td');
            let td6 = document.createElement('td');
            let table = document.querySelector('table');
            table.append(tr2);
            tr2.append(td)
            tr2.append(td4);
            tr2.append(td5);
            tr2.append(td6);
            tr2.className = "tr2";
            td.colSpan = 4;
            td.innerText = "Gross details (KES)"
            td4.innerText = Number((grossAmount - grossValueGain).toFixed(2)).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });;
            td5.innerText = Number(grossValueGain.toFixed(2)).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            td6.innerText = Number(grossAmount.toFixed(2)).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });;

        }
        /*  function gross() {
              grossAmount1 = Number(grossAmount.toFixed(2)).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
              grossValueGain1 = Number(grossValueGain.toFixed(2)).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
              document.querySelector('.display').innerText = `Gross value gain is KES ${grossValueGain1}
              Gross amount is KES ${grossAmount1}`
          }*/
        document.querySelector('#download').addEventListener('click', () => {
            let element = document.querySelector('#table');
            html2canvas(element).then(canvas => {
                const imgData = canvas.toDataURL("image/png");
                const { jsPDF } = window.jspdf;
                let pdf = new jsPDF();
                let imgWidth = 210;   // width of A4 page in mm
                let pageHeight = 295; // height of A4 page in mm
                let imgHeight = canvas.height * imgWidth / canvas.width;
                pdf.addImage(imgData, 'PNG', 0, 0, imgWidth, imgHeight);
                pdf.save("price_action.pdf");

            });
        });



    </script>
</body>

</html>
